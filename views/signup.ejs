<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Signup - Book Review</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <style>
        body { background-color: #0B1714; color: white; display: flex; align-items: center; justify-content: center; height: 100vh; margin: 0; }
        .auth-card { background: rgba(255, 255, 255, 0.1); padding: 2rem; border-radius: 10px; width: 100%; max-width: 400px; }
        input { background: #172526 !important; border: 1px solid #D0BEAD !important; color: white !important; }
        .btn-primary { background-color: #0a1613; border: none; }
        .btn-primary:hover { background-color: #1a2b27; }
        a { color: #D0BEAD; text-decoration: none; }
    </style>
</head>
<body>
    <div class="auth-card">
        <h2 class="text-center mb-4">Signup</h2>
        <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
        <% } %>
        <form action="/auth/signup" method="POST">
            <div class="mb-3">
                <label class="form-label">Username</label>
                <input type="text" name="username" class="form-control" required>
            </div>
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control" required>
            </div>
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" name="password" class="form-control" required>
            </div>
            <button type="submit" class="btn btn-primary w-100">Signup</button>
        </form>
        <p class="mt-3 text-center">Already have an account? <a href="/auth/login">Login</a></p>
    </div>
</body>
</html>
