<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Review</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
               body {
            background-color: #0B1714 !important; /* Same background color */
            color: #ffffff !important; /* Same text color */
            font-family: Arial, sans-serif; /* Consistent font */
            padding: 20px; /* Padding around the body */
            font-family: 'Roboto', sans-serif ; /* Body font */
           
        }

        h1 {
            color: #ffffff !important; /* Heading color */
            text-align: center !important; /* Center the heading */
            font-family: 'Playfair Display', serif !important; /* Heading font */
            font-size: 35px !important;
        }
    </style>
</head>
<body>
    <div class="header">
        <%- include('header') %>
    </div>
    <div class="container">
        <h1><%= book.title %></h1> 
        <p><strong>Review by:</strong> <%= book.author %></p>
        <p><strong>Rating:</strong> <%= book.rating %></p>
        <p id="full-review-text"><%= book.review %></p></a>
            
           <!-- Button to go back to the previous page -->
           <button onclick="history.back()" class="btn btn-primary mt-3">
            Go Back
        </button>
    </div>
    
    <%- include('footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>


