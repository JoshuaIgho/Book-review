<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Book</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Roboto:wght@400&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #0B1714 !important; /* Same background color */
            color: #ffffff !important; /* Same text color */
            font-family: Arial, sans-serif; /* Consistent font */
            padding: 20px; /* Padding around the body */
            font-family: 'Roboto', sans-serif; /* Body font */
           
        }
        

        h1, h2, h3  {
            color: #D0BEAD; /* Heading color */
            text-align: center; /* Center the heading */
            font-family: 'Playfair Display', serif; /* Heading font */
        }
        

        form {
            max-width: 600px; /* Max width for form */
            margin: 0 auto; /* Center the form */
            background-color: rgba(255, 255, 255, 0.1); /* Semi-transparent background for form */
            border-radius: 10px; /* Rounded corners */
            padding: 20px; /* Padding inside form */
        }

        input, textarea {
            width: 100%; /* Full width inputs */
            margin-bottom: 5px !important; /* Space between inputs */
            padding: 10px; /* Padding inside inputs */
            border: 1px solid #D0BEAD; /* Border color */
            border-radius: 5px; /* Rounded corners */
            background-color: #172526; /* Dark background for inputs */
            color: #D0BEAD; /* Text color inside inputs */
        }

        input::placeholder, textarea::placeholder {
            color: rgba(255, 255, 255, 0.5); /* Placeholder text color */
        }

        button {
            width: 100%; /* Full width button */
            padding: 10px; /* Padding inside button */
            background-color: #0a1613; /* Button background color */
            color: white; /* Button text color */
            border: none; /* Remove border */
            border-radius: 5px; /* Rounded corners */
            cursor: pointer; /* Pointer cursor on hover */
            font-size: 16px; /* Font size */
            margin-top: 10px; /* Space above button */
        }

        button:hover {
            background-color: #0b1714; /* Darker background on hover */
        }

        .cancel-button {
            background-color: #b22222; /* Red background for cancel button */
            margin-top: 10px; /* Space above cancel button */
        }

        .cancel-button:hover {
            background-color: #a60000; /* Darker red on hover */
        }

        a {
            display: inline-block; /* Inline block for link */
            margin-top: 20px; /* Space above link */
            color: #D0BEAD; /* Link color */
            text-decoration: none; /* Remove underline */
            text-align: center; /* Center the link */
        }

        a:hover {
            text-decoration: underline; /* Underline on hover */
        }
        .nav-link {
            color: #D0BEAD; /* Default text color for links */
            transition: background-color 0.3s, color 0.3s; /* Smooth transition for background and text color */
            text-decoration: none !important;
            border-bottom: 2px solid transparent; /* Invisible border */
            margin-bottom: 0px;
        }
        

        .nav-link.active {
            background-color: #0a1613 !important; /* Set the active link background color */
            color: white; /* Ensure text color is white for better contrast */
            border-radius: 5px; /* Optional: Add rounded corners */
        }

        .nav-link:hover{
            color: #a8e6cf !important; /* Change color on hover for better visibility */
            border-bottom: 2px solid #d6d1d1; /* Add visible border on hover */
        }
    </style>
</head>
<body>
    <%- include('header') %>
    <h1>Edit Book</h1>
    <form action="/books/edit/<%= book.id %>" method="POST" enctype="multipart/form-data">
        <input type="text" name="title" value="<%= book.title %>" required>
        <input type="text" name="author" value="<%= book.author %>" required>
        <input type="number" name="rating" value="<%= book.rating %>" min="1" max="5" required>
        <textarea name="review" ><%= book.review %></textarea>
        <input type="date" name="read_date" value="<%= book.read_date %>" required>
        <input type="hidden" name="existing_cover_url" value="<%= book.cover_url %>">
        <input type="file" name="cover_file" accept="image/*">
        
        <button type="submit">Update Book</button>
        <button type="button" class="cancel-button" onclick="window.location.href='/books'">Cancel</button>
    </form>
    <%- include('footer') %>
</body>
</html>