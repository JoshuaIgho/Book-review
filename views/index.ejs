<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Review</title>
    <link rel="stylesheet" href="../styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <style>
     .tags {
    background: none;
    border: none;
    padding: 0;
    text-decoration: none;
    cursor: pointer;
    font-size: 20px;
    font-weight: bold;
    color: white;
    text-align: left; /* Align text to the left */
    white-space: normal; /* Allow text to wrap */
    word-wrap: break-word; /* Break long words if necessary */
    max-width: 100%; /* Ensure it respects container size */
    transition: color 0.3s ease, text-decoration 0.3s ease; /* Smooth hover effect */
}

.tags:hover {
    color: rgba(0, 0, 0, 0.445); /* Change text color on hover */
}
.yu{
    background-color: transparent;
    color: white;
}
.qw, .er, .ty{
    color: white !important;
}

    </style>
</head>
<body>
    <div class="header">
        <%- include('header') %>
    </div>

    <section class="grid--container">
        <% books.forEach(book => { %>
        <div class="grid--cell">
            <article class="grid--item">
                <div class="preview--container">                
                    <a href="#" class="preview-image--container">
                        <div class="preview-image" style="background-image: url('<%= book.cover_url || "/images/default-cover.jpg" %>');"></div>
                    </a>
                </div>
                <div class="content--container">
                    <div class="title--container">
                 

                        <form action="/books/review" method="POST">
                            <input type="hidden" name="bookId" value="<%= book.id %>">
                            <!-- Use a button styled as a link -->
                            <button type="submit" class="tags">
                                <%= book.title %>
                            </button>
                        </form>
                        
                    </div>
                    <div class="tags--overflow-container">
                        <ul class="tags--container">
                            <li><a href="#" class="tag qw">Author: <%= book.author %></a></li>
                            <li><a href="#" class="tag er">Rating: <%= book.rating %></a></li>
                            <li><form action="/books/review" method="POST">
                                <input type="hidden" name="bookId" value="<%= book.id %>">
                                <button type="submit" class="tag yu">
                                    Review: <%= book.review.substring(0, 0) %>
                                    <i class="fas fa-arrow-circle-right styled"></i>
                                </button>
                            </form>
                            </li>
                            <li>
                               <a href="#" class="tag ty">Read date: <%= book.read_date %></a> 
                            </li>
                        </ul>
                    </div>
                    <div class="hover--options">
                        <a href="/books/edit/<%= book.id %>" class="series button">
                            <span class="icon-title"><i class="fas fa-book"></i> Edit</span>
                            <span class="new-tab"><i class="fas fa-arrow-circle-right"></i></span>        
                        </a>
                        <form action="/books/<%= book.id %>?_method=DELETE" method="POST" style="display:inline;">
                            <button type="submit" class="latest button" style="border:none; background:none; padding:0; width:100%; text-align:left;">
                                <span class="icon-title">Delete</span>
                                <span class="new-tab"><i class="fas fa-arrow-circle-right"></i></span>
                            </button>
                        </form>
                    </div>
                </div>
            </article>
        </div>
        <% }); %>
    </section>

    <%- include('footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>
