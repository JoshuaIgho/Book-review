<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Review</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Roboto:wght@400&display=swap" rel="stylesheet">
    <style>
    
    * {
  padding: 0;
  margin: 0;
  box-sizing: border-box;
  font-family: 'Roboto' sans-serif;
  text-decoration: none;
  list-style: none;
}
body {
    font-family: 'Roboto', sans-serif; /* Body font */
    
    }

.header {
  position: relative;
  top: -10px;
  width: 100%;
  background-color: transparent;
  z-index: 1;
  margin-bottom: 10px;
}
nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 10px;
  border-bottom: 1px solid white;
}

.logo a {
  font-size: 24px;
  font-weight: bold;
  color: #fff;
  text-decoration: none;

}

.logo a span {
  color: #8739fa;
}

.menu {
  display: flex;
  justify-content: center;
  align-items: center;
}

.menu a {
  display: block;
  padding: 7px 15px;
  font-size: 17px;
  font-weight: 500;
  transition: 0.2s all ease-in-out;
  color: #fff;
  text-decoration: none;
}

.menu:hover a {
  opacity: 0.4;
}

.menu a:hover {
  opacity: 1;
  color: #fff;
}

.menu-icon {
  display: none;
}

#menu-toggle {
  display: none;
}

#menu-toggle:checked ~ .menu {
  transform: scale(1, 1);
}

@media only screen and (max-width: 950px) {
  .menu {
    flex-direction: column;
    background-color: #151418;
    align-items: start;
    position: absolute;
    top: 40px;
    left: 220px;
    width: 100%;
    padding-left: 10px;
    padding-top: 20px;
    z-index: 1;
    transform: scale(1, 0);
    transform-origin: top;
    transition: transform 0.3s ease-in-out;
    box-shadow: rgba(0, 0, 0, 0.15) 1.95px 1.95px 2.6px;
    border-radius: 10px;
  }

  .menu a {
    margin-left: 12px;
  }

  .menu li {
    margin-bottom: 10px;
  }

  .menu-icon {
    display: block;
    color: #fff;
    font-size: 28px;
    cursor: pointer;
  }

  nav{
    border-bottom: none;
  }
  
 
}

    </style>
</head>
<body>
    <header class="header">
        <nav>
          <div class="logo">
            <a href="/">BOOK.<span>REVIEW</span></a>
          </div>
          <input type="checkbox" id="menu-toggle">
          <label for="menu-toggle" class="menu-icon">&#9776;</label>
          <ul class="menu">
            <li class="nav-item"><a href="/">Home</a></li>
            <% if (user) { %>
              <li class="nav-item"><a href="/books/add">Add Book</a></li>
              <li class="nav-item"><a href="/auth/logout">Logout (<%= user.username %>)</a></li>
            <% } else { %>
              <li class="nav-item"><a href="/auth/login">Login</a></li>
              <li class="nav-item"><a href="/auth/signup">Signup</a></li>
            <% } %>
            <li class="nav-item"><a href="/books/about">About</a></li>
            <li class="nav-item"><a href="/books/contact">Contact</a></li>
          </ul>
        </nav>
      </header>
</html>

